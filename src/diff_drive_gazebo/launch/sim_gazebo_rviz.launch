<launch>
  <param name="use_sim_time" value="true"/>

  <param name="robot_description" textfile="$(find diff_drive_gazebo)/urdf/robot2.urdf"/>

  <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher"/>

  <include file="$(find gazebo_ros)/launch/empty_world.launch">
      <arg name="paused" value="false"/>
      <arg name="use_sim_time" value="true"/>
      <arg name="gui" value="true"/>
      <arg name="world_name" value="$(find diff_drive_gazebo)/worlds/kexueguan205.world"/>
  </include>

  <node pkg="gazebo_ros" type="spawn_model" name="spawn_model" output="screen"
    args="-urdf -param robot_description -model tri_steer
          -x 0.0 -y 0.0 -z 0.0"/>

  <node pkg="map_server" type="map_server" name="map_server" args="$(find diff_drive_gazebo)/map/carto_mapf.yaml"/>

  <!-- 静态 map->odom TF -->
  <node pkg="tf2_ros" type="static_transform_publisher" name="link_broadcaster" args="0 0 0 0 0 0 map odom" />

  <node pkg="rviz" type="rviz" name="rviz" args="-d $(find diff_drive_gazebo)/rviz/tri_steer.rviz"/>
</launch>